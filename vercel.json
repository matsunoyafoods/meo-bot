{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/poll-reviews",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/weekly-article",
      "schedule": "0 2 * * 1,3,5"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "30 1 * * 1"
    }
  ],
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 60
    }
  }
}
