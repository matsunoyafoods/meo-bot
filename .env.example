# ---------- App ----------
# 公開URL（末尾スラッシュなし）。Vercel 本番ドメイン。
NEXT_PUBLIC_APP_URL=https://meo-bot.vercel.app

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# service_role キー（サーバー専用・絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=123456789:AA...
# webhook を検証するシークレット（自分で決めた任意の文字列）
TELEGRAM_WEBHOOK_SECRET=some-long-random-string

# ---------- Google OAuth / Business Profile ----------
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# OAuth リダイレクト先（下の callback ルートに合わせる）
GOOGLE_OAUTH_REDIRECT_URI=https://meo-bot.vercel.app/api/oauth/google/callback

# ---------- Gemini ----------
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ---------- Cron 保護 ----------
# Vercel Cron / 外部スケジューラからの呼び出しを検証する共有シークレット
CRON_SECRET=another-long-random-string
